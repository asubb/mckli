<configuration debug="false">
    <appender name="DAEMON_FILE" class="ch.qos.logback.core.FileAppender">
        <file>${MCKLI_LOG_DIR:-${user.home}/.mckli/daemons}/mckli-daemon.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="CLI_FILE" class="ch.qos.logback.core.FileAppender">
        <file>${MCKLI_LOG_DIR:-${user.home}/.mckli/logs}/mckli-run.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${MCKLI_STDOUT_LOG_LEVEL:-WARN}</level>
        </filter>
    </appender>

    <root level="INFO">
        <appender-ref ref="${mckli.log.appender:-CLI_FILE}" />
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
