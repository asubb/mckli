#!/bin/bash

set -e

if [[ "$1" == "--kill" ]]; then
    # Kill only mckli Java processes (MainKt or DaemonMainKt)
    # We look for 'java' and the specific main classes
    pids=$(ps aux | grep java | grep -E "com\.mckli\.(MainKt|daemon\.DaemonMainKt)" | grep -v grep | awk '{print $2}')
    if [ -n "$pids" ]; then
        echo "Killing mckli instances: $pids"
        kill -9 $pids || true
    else
        echo "No mckli instances found."
    fi
    exit 0
fi

if ! gradle_output=$(./gradlew installDist 2>&1); then
    echo "$gradle_output"
    exit 1
fi

export MCKLI_CONFIG_DIR=$(pwd)/.test-home/
export MCKLI_LOG_DIR=$(pwd)/.test-home/logs/
export MCKLI_DAEMONS_DIR=$(pwd)/.test-home/daemon/
export MCKLI_STDOUT_LOG_LEVEL=WARN

mkdir -p "$MCKLI_CONFIG_DIR"
mkdir -p "$MCKLI_LOG_DIR"
mkdir -p "$MCKLI_DAEMONS_DIR"

build/install/mckli/bin/mckli "$@"